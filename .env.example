# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit a real key.

# Groq API key. Used server-side only (never exposed to the browser).
# Free tier: 1,000 req/day, 30 RPM, no credit card needed.
# Get one at https://console.groq.com/ → API Keys
GROQ_API_KEY=
