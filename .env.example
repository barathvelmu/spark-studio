# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit a real key.

# Anthropic API key. Used server-side only (never exposed to the browser).
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional model overrides (sensible defaults applied if omitted)
# ANTHROPIC_MODEL_GENERATE=claude-sonnet-4-6
# ANTHROPIC_MODEL_ASK=claude-haiku-4-5-20251001
